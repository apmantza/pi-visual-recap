{
	"name": "pi-visual-recap",
	"version": "0.1.0",
	"description": "Pi-native visual recap for commits, branches, PRs, and Pi sessions",
	"type": "module",
	"keywords": ["pi-package", "visual-recap", "review", "diff", "pr"],
	"pi": {
		"extensions": ["./extensions/visual-recap/entrypoint.ts"],
		"skills": ["./skills"]
	},
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit -p tests/tsconfig.json",
		"typecheck:ext": "tsc --noEmit -p extensions/visual-recap/tsconfig.json",
		"lint": "biome check ."
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"vitest": "^2.1.0",
		"typescript": "^5.6.0"
	}
}
